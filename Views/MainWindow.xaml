<Window x:Class="RecallFinanceApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recall Finance v1.0" Height="650" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <DockPanel>
        <StackPanel DockPanel.Dock="Left" Width="180" Background="#2C3E50">
            <TextBlock Text="RECALL PRO" Foreground="White" FontSize="18" 
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,30"/>
            
            <Button Content="📊 Dashboard" Click="NavDashboard_Click" Margin="10,5" Padding="10"/>
            <Button Content="⚙️ Ayarlar" Click="NavSettings_Click" Margin="10,5" Padding="10"/>
        </StackPanel>

        <ContentControl Content="{Binding CurrentView}" Margin="20"/>
    </DockPanel>
</Window>